# Normalize all text files and preserve binary files
* text=auto

# Force these file types to LF in the repository and working tree
*.md text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.mjs text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
